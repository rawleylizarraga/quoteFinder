<%- include("partials/header.ejs") %>

<body>
    <div class="page">
        <header>
            <h1> Quotes Found </h1>
        </header>

        <main>

            <% for (i of quotes) { %>
                <div class="quote">
                    <%= i.quote %> <br>
                    -<em>   <a href="#" id="<%= i.authorId %>">
                            <%= i.firstName %> <%= i.lastName %> 
                            </a>
                    </em> 
                </div>
                
                <br>

            <% } %>


            

            <!-- Modal -->
            <div class="modal fade"  id="authorModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
                <div class="modal-dialog">
                    <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title fs-5" id="exampleModalLabel">Author Information</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div id="authorInfo"></div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                        <!-- <button type="button" class="btn btn-primary">Save changes</button> -->
                    </div>
                    </div>
                </div>
            </div>
        </main>


        <%- include("partials/footer.ejs") %>
    </div>
    

    <script src="/js/script.js"></script>
</body>

</html>