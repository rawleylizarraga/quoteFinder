<%- include("partials/header.ejs") %>

<body>
    <div class="page">
       <header>
            <h1> Quote Finder </h1>
        </header>

        <main>
            <form action="/searchByKeyword">
                <h4>Keyword:</h4>
                <input type="text" name="keyword" required>
                <button>Search by Keyword</button>
            </form>

            <br>

            <form action="/searchByAuthor">
                <h4>Author:</h4>
                <select name="authorId">
                    <% for (let author of authors) { %>
                    <option value="<%= author.authorId %>">
                        <%= author.firstName %> <%= author.lastName %>
                    </option>
                    <% } %>
                </select>
                <button> Search by Author </button>
            </form>

            <br>

            <form action="/searchByCategory">
                <h4>Category:</h4>
                <select name="category">
                    <% for (let category of categories) { %>
                    <option value="<%= category.category %>">
                        <%= category.category %>
                    </option>
                    <% } %>
                </select>
                <button> Search by Category </button>
            </form>

            <br>

            <form action="/searchByLikes">
                <h4>Likes:</h4>
                Min:
                <input type="text" id="minLikes" name="minLikes" class="numInput" value="0" required>
                Max:
                <input type="text" id="maxLikes" name="maxLikes" class="numInput" value="100" required>
                <button id="likesBtn"> Search by Likes </button>
            </form>
        </main>

        <%- include("partials/footer.ejs") %>
    </div>

    <script src="/js/script.js"></script>
</body>

</html>